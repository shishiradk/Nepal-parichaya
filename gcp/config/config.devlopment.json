{
  "environment": "development",
  "config_version": "1.0",
  "config_source": "json_file",
  
  "processor": {
    "project_id": "your-dev-project-id",
    "processor_id": "your-dev-processor-id",
    "location": "us",
    "processor_version": "pretrained-ocr-v2.1-2024-07-01",
    "language_hints": ["ne"]
  },
  
  "storage": {
    "input_gcs_uri": "gs://your-dev-bucket/input/test-document.pdf",
    "output_gcs_uri": "gs://your-dev-bucket/output/",
    "mime_type": "application/pdf"
  },
  
  "processing": {
    "wait_for_completion": true,
    "extract_text": true,
    "save_pages": true,
    "poll_interval": 30,
    "max_wait_time": 3600
  },
  
  "output": {
    "output_dir": "extracted_text_dev",
    "log_file": "batch_ocr_dev.log",
    "log_level": "DEBUG",
    "save_statistics": true
  },
  
  "ocr": {
    "enable_native_pdf_parsing": true,
    "enable_image_quality_scores": true,
    "enable_symbol": true,
    "advanced_ocr_options": ["ENABLE_FONT_IDENTIFICATION"]
  },
  
  "security": {
    "service_account_key_path": "./keys/dev-service-account.json",
    "use_default_credentials": false
  }
}